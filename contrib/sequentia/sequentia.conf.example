# Sequentia node reference configuration.
#
# See doc/sequentia/09-running-sequentia.md for the full runbook.
#
# IMPORTANT: the CONSENSUS settings below must be IDENTICAL on every operator's
# node — Sequentia runs as an Elements custom chain, so the genesis block and
# all rules are derived from them, and any mismatch forks the network or
# changes the genesis. Keep this block in shared, version-pinned config. The
# NODE-LOCAL settings at the bottom (credentials, ports, parent connection) are
# per-operator and must NOT be shared.

# ============================================================================
# CONSENSUS (shared verbatim by all operators)
# ============================================================================

chain=sequentia

# (1) Open / "no-coin" fee market: any issued asset may pay fees.
con_any_asset_fees=1

# (2) Bitcoin anchoring: every block references a parent Bitcoin block at a
#     non-decreasing height; the chain reorganizes iff Bitcoin does.
con_bitcoin_anchor=1

# (3) Proof-of-Stake: private VRF sortition + MuSig2-aggregated committee.
con_pos=1
posvrf=1
posaggcommittee=1
poscommitteesize=51        # expected committee size (<=100 with aggregation)
posslotinterval=10         # seconds per VRF sortition slot
posunbonding=2016          # CSV blocks a stake locks before it counts / can unbond

# The genesis staker set: one line per founding staker, <pubkey-hex>:<weight>.
# This is a GOVERNANCE decision and must match on every node. Replace these.
#staker=02aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa:1000000
#staker=03bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb:1000000

# (4) Bitcoin-identical default addresses; confidential transactions opt-in.
con_default_blinded_addresses=0

# PoS computes the per-block signing challenge; this is the placeholder script.
signblockscript=51

# Published long-range-attack checkpoints (append over the network's life).
#poscheckpoint=100000:<blockhash>
#poscheckpoint=200000:<blockhash>
poscheckpointdepth=6

# ============================================================================
# NODE-LOCAL (per operator — do NOT share)
# ============================================================================

# RPC server for elements-cli / your tooling.
server=1
rpcuser=CHANGE_ME
rpcpassword=CHANGE_ME_TO_A_LONG_RANDOM_STRING
#rpcport=7041
#port=7040

# Parent Bitcoin node, for anchoring (and any optional peg use).
validateanchor=1
anchorminconf=1
mainchainrpchost=127.0.0.1
mainchainrpcport=8332
# Prefer cookie auth; or set mainchainrpcuser / mainchainrpcpassword.
mainchainrpccookiefile=/home/YOU/.bitcoin/.cookie

# Dynamic fee rates expire if the price server stops (fail-closed). Tune to
# your price-server poll cadence (see contrib/price-server/).
#dynfeeratemaxage=300
