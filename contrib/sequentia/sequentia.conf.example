# Sequentia node reference configuration.
#
# See doc/sequentia/05-operating-sequentia.md for the full runbook.
#
# TO JOIN THE PUBLIC TESTNET you do not need most of this file: the `test`
# chain bakes its consensus rules and defaults the shared gateway endpoints.
# The minimal config is:
#
#   chain=test
#
#   [test]
#   pospubliccommittee=1     # network-wide consensus rules of the current
#   poscommitteesize=250     # chain (re-genesis 2026-07-05); must be set.
#   server=1
#   rpcuser=CHANGE_ME
#   rpcpassword=CHANGE_ME
#
# The rest of this file is the reference for a CUSTOM chain (a local or shared
# development network whose genesis is derived from configuration).
#
# IMPORTANT: on a custom chain the CONSENSUS settings below must be IDENTICAL
# on every operator's node — the genesis block and all rules are derived from
# them, and any mismatch forks the network or changes the genesis. Keep this
# block in shared, version-pinned config. The NODE-LOCAL settings at the
# bottom (credentials, ports, parent connection) are per-operator and must NOT
# be shared.

# ============================================================================
# CONSENSUS (shared verbatim by all operators of a custom chain)
# ============================================================================

chain=seqcustom              # a custom chain name shared by all operators

# (1) Open / "no-coin" fee market: any issued asset may pay fees.
con_any_asset_fees=1

# (2) Bitcoin anchoring: every block references a parent Bitcoin block at a
#     non-decreasing height; the chain reorganizes iff Bitcoin does.
con_bitcoin_anchor=1

# (3) Proof-of-Stake: private VRF leader sortition + BLS-aggregated committee
#     certification (MuSig2 is the posbls=0 fallback).
con_pos=1
posvrf=1
posbls=1
pospubliccommittee=1       # public fixed-size committee (what the public
                           # testnet runs); omit for threshold VRF sortition.
poscommitteesize=250       # committee cap under the public committee (actual
                           # committee = min(#registered stakers, cap); quorum
                           # = strict majority, +1 at odd sizes). Under
                           # threshold sortition: expected size, max 100,
                           # fixed majority quorum.
posslotinterval=30         # seconds per slot; 30s on the bundled chains
# Minimum unbonding lock, in (Sequentia) blocks; the required wall-clock lock
# is this x posslotinterval. The whitepaper (§3.11) requires the lock to
# exceed the 2016-BTC-block (~2 week) checkpoint window, so stakers cannot
# unbond and then rewrite checkpointed history. At 30s slots ~2 weeks = 40,320
# blocks; 43200 (~15 days) clears it. This exceeds the 16-bit height-CSV
# range, so staking outputs must use a TIME-BASED CSV lock
# (getstakescript ... csv_seconds=...).
posunbonding=43200
con_blocksubsidy=0         # no inflation: SEQ is pre-mined at genesis, never
                           # minted by block production; stakers earn fees only
                           # (whitepaper §3.9). 0 is also the custom-chain default.
posminstake=4000000000000  # minimum stake to be a blocksigner, in SEQ atoms:
                           # 0.01% of supply = 40,000 SEQ (whitepaper §3.3).
                           # 40000 * 1e8 atoms. 0 disables the floor.

# Genesis stake seed (governance; identical on every node): either a genesis
# staking output plus spendable coins (the bundled chains' model) ...
#con_genesis_stake=02<pubkey-hex>:<amount_atoms>:<csv>
#initialfreecoins=<atoms>
# ... or a config staker set, one line per founding staker. Append
# :<blspubkey>:<pop> (from getblsregistration) when running the public
# committee.
#staker=02<pubkey-hex>:1000000
#staker=03<pubkey-hex>:1000000

# Block weight cap: 200,000 (a twentieth of Bitcoin's), so at ~30s blocks a
# saturated chain grows at Bitcoin's rate (whitepaper §3.10). ~50 KB/block.
con_maxblockweight=200000

# (4) Bitcoin-identical default addresses; confidential transactions opt-in.
con_default_blinded_addresses=0

# PoS computes the per-block signing challenge; this is the placeholder script.
signblockscript=51

# Published long-range-attack checkpoints (append over the network's life).
#poscheckpoint=100000:<blockhash>
#poscheckpoint=200000:<blockhash>
poscheckpointdepth=2016    # parent-chain (Bitcoin) confirmations before a
                           # checkpoint finalizes: ~2 weeks (whitepaper §3.11)

# ============================================================================
# NODE-LOCAL (per operator — do NOT share)
# ============================================================================

# RPC server for elements-cli / your tooling.
server=1
rpcuser=CHANGE_ME
rpcpassword=CHANGE_ME_TO_A_LONG_RANDOM_STRING
#rpcport=7041
#port=7040

# Parent Bitcoin node, for anchoring (and any optional peg use).
validateanchor=1
anchorminconf=1
mainchainrpchost=127.0.0.1
mainchainrpcport=8332
# Prefer cookie auth; or set mainchainrpcuser / mainchainrpcpassword.
mainchainrpccookiefile=/home/YOU/.bitcoin/.cookie

# Note on fee-asset acceptance: the node keeps ONE fee-asset whitelist
# (setfeeexchangerates / getfeeexchangerates), optionally kept fresh by the
# price-server sidecar in contrib/price-server/. The node holds the last-set
# rates indefinitely; the sidecar owns freshness and clears the whitelist on
# clean shutdown. See doc/sequentia/02-open-fee-market.md.
